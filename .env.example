# ── Backend (.env in backend/) ──────────────────────────────────────────────

# OpenAI — used for Realtime voice API and embeddings
OPENAI_API_KEY=sk-...

# OpenRouter — used for chat LLM (e.g. openai/gpt-4o-mini)
OPENROUTER_API_KEY=sk-or-...

# Firecrawl — used to scrape pages during knowledge base ingestion
FIRECRAWL_API_KEY=fc-...

# PostgreSQL with pgvector extension
DATABASE_URL=postgresql://user:password@localhost:5432/supportagent

# LLM / embedding model overrides (defaults shown)
LLM_MODEL=openai/gpt-4o-mini
EMBED_MODEL=text-embedding-3-small
TTS_VOICE=alloy

# Google Calendar OAuth — run scripts/get_google_token.py to obtain refresh token
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
SUPPORT_EMAIL=support@yourdomain.com

# Slack — incoming webhook URL for escalation notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Admin panel credentials (shown in /admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-use-a-strong-password

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# Uvicorn workers (Docker only, default 1)
WORKERS=4


# ── Frontend (.env in frontend/) ────────────────────────────────────────────

# URL of the backend API (no trailing slash)
VITE_API_URL=http://localhost:8000
